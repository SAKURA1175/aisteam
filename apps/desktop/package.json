{
  "name": "@tutormarket/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop shell for Eggshell Companion.",
  "author": "TutorMarket AI",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "node ./scripts/dev.cjs",
    "prepare-web": "node ./scripts/prepare-web.cjs",
    "pack:win": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ai.tutormarket.eggshell.desktop",
    "productName": "Eggshell Companion",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".dist/web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "protocols": [
      {
        "name": "Eggshell Auth",
        "schemes": [
          "eggshell"
        ]
      }
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
